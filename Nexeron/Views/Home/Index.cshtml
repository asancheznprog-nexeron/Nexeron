    </main>

    <script>
        function toggleSubmenu(id, element, theme) {
            var panel = document.getElementById("submenuPanel");
            var contents = document.getElementsByClassName("submenu-content");
            var cards = document.getElementsByClassName("card");
            var target = document.getElementById(id);
            var active = element.classList.contains("active");

            if (active) {
                element.classList.remove("active");
                panel.classList.remove("open");
                target.classList.remove("active");
            } else {
                var alreadyOpen = panel.classList.contains("open");

                for (var i = 0; i < cards.length; i++) {
                    cards[i].classList.remove("active");
                }
                for (var i = 0; i < contents.length; i++) {
                    contents[i].classList.remove("active");
                }

                if (alreadyOpen) {
                    panel.style.height = "0px";
                    panel.style.paddingTop = "0px";
                    panel.style.paddingBottom = "0px";
                    panel.style.marginTop = "0px";
                    panel.style.borderWidth = "0px";

                    setTimeout(function () {
                        element.classList.add("active");
                        panel.className = "submenu-panel open " + theme;
                        panel.removeAttribute("style");
                        target.classList.add("active");
                    }, 250);
                } else {
                    element.classList.add("active");
                    panel.className = "submenu-panel open " + theme;
                    target.classList.add("active");
                }
            }
        }

        function toggleDropdown() {
            document.getElementById("userMenu").classList.toggle("show");
        }

        window.onclick = function (event) {
            if (!event.target.matches('.dropbtn') && !event.target.closest('.dropbtn')) {
                var dropdowns = document.getElementsByClassName("dropdown-content");
                for (var i = 0; i < dropdowns.length; i++) {
                    var openDropdown = dropdowns[i];
                    if (openDropdown.classList.contains('show')) {
                        openDropdown.classList.remove('show');
                    }
                }
            }
        }
    </script>
</body>
</html>