@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Panel de Control";

    string usuarioActual = Session["Usuario"] as string ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Nexeron</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            color: #333;
        }

        .greeting {
            font-size: 1rem;
            color: #555;
        }

        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropbtn {
            background-color: transparent;
            color: #333;
            padding: 0.4rem 0.6rem;
            font-size: 1.5rem;
            border: 1px solid transparent;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background-color 0.2s, border-color 0.2s;
        }

            .dropbtn:hover, .dropbtn:focus {
                background-color: #f1f3f5;
                border-color: #ddd;
            }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            background-color: #ffffff;
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.1);
            z-index: 1;
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid #eee;
            margin-top: 0.5rem;
        }

            .dropdown-content a {
                color: #333;
                padding: 12px 16px;
                text-decoration: none;
                display: block;
                font-size: 0.95rem;
                transition: background-color 0.2s;
            }

                .dropdown-content a:hover {
                    background-color: #f1f3f5;
                }

        .dropdown-divider {
            height: 1px;
            background-color: #eaeaea;
            margin: 0;
        }

        .text-danger {
            color: #dc3545 !important;
            font-weight: bold;
        }

            .text-danger:hover {
                background-color: #fff0f0 !important;
            }

        .show {
            display: block;
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1.5rem;
        }

        .page-header {
            margin-bottom: 2rem;
        }

            .page-header h2 {
                margin: 0 0 0.5rem 0;
                font-size: 1.8rem;
            }

            .page-header p {
                color: #666;
                margin: 0;
            }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            color: inherit;
            transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;
            border-top: 4px solid #007bff;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            user-select: none;
            box-sizing: border-box;
            height: 100%;
        }

            .card:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 12px rgba(0,0,0,0.1);
            }

            .card.ventas {
                border-top-color: #28a745;
            }

            .card.compras {
                border-top-color: #17a2b8;
            }

            .card.referencias {
                border-top-color: #ffc107;
            }

            .card.contabilidad {
                border-top-color: #6f42c1;
            }

            .card.active.ventas {
                background-color: #f8fbf9;
                box-shadow: inset 0 0 0 1px #28a745;
            }

            .card.active.compras {
                background-color: #f4fafd;
                box-shadow: inset 0 0 0 1px #17a2b8;
            }

            .card.active.referencias {
                background-color: #fffdf4;
                box-shadow: inset 0 0 0 1px #ffc107;
            }

            .card.active.contabilidad {
                background-color: #f9f6fc;
                box-shadow: inset 0 0 0 1px #6f42c1;
            }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin-bottom: 0.5rem;
        }

        .card h3 {
            margin: 0;
            font-size: 1.2rem;
        }

        .card p {
            margin: 0;
            color: #666;
            font-size: 0.95rem;
            line-height: 1.4;
        }

        .card-icon {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
        }

        .card.ventas .card-icon {
            color: #28a745;
        }

        .card.compras .card-icon {
            color: #17a2b8;
        }

        .card.referencias .card-icon {
            color: #ffc107;
        }

        .card.contabilidad .card-icon {
            color: #6f42c1;
        }

        .submenu-panel {
            height: 0;
            overflow: hidden;
            background-color: #ffffff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: height 0.25s ease-in-out, margin-top 0.25s ease-in-out, padding 0.25s ease-in-out;
            margin-top: 0;
            padding: 0 2rem;
            box-sizing: border-box;
            width: 100%;
        }

            .submenu-panel.open {
                height: 340px;
                margin-top: 2.5rem;
                padding: 2rem;
                border: 1px solid #eee;
            }

        .submenu-content {
            display: none;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            height: 100%;
            box-sizing: border-box;
        }

            .submenu-content.active {
                display: grid;
            }

        #sub-ventas, #sub-compras, #sub-referencias {
            grid-template-rows: repeat(2, 1fr);
        }

        #sub-contabilidad {
            grid-template-rows: repeat(4, 1fr);
        }

        .submenu-content a {
            color: #333;
            padding: 1rem 1.5rem;
            text-decoration: none;
            font-size: 1.25rem;
            font-weight: bold;
            border-radius: 8px;
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            transition: background-color 0.2s, color 0.2s, padding-left 0.2s;
            border: 1px solid #eaeaea;
            box-sizing: border-box;
            height: 100%;
        }

        #sub-contabilidad a {
            font-size: 1.1rem;
            padding: 0.5rem 1.5rem;
        }

        #sub-compras a:last-child {
            grid-column: span 2;
        }

        .submenu-content a:hover {
            padding-left: 2rem;
        }

        .submenu-icon {
            width: 28px;
            height: 28px;
            margin-right: 16px;
            flex-shrink: 0;
        }

        #sub-contabilidad .submenu-icon {
            width: 22px;
            height: 22px;
        }

        .submenu-panel.panel-ventas a:hover {
            background-color: #28a745;
            color: #ffffff;
            border-color: #28a745;
        }

        .submenu-panel.panel-compras a:hover {
            background-color: #17a2b8;
            color: #ffffff;
            border-color: #17a2b8;
        }

        .submenu-panel.panel-referencias a:hover {
            background-color: #ffc107;
            color: #333333;
            border-color: #ffc107;
        }

        .submenu-panel.panel-contabilidad a:hover {
            background-color: #6f42c1;
            color: #ffffff;
            border-color: #6f42c1;
        }
    </style>
</head>
<body>

    <main class="container">
        <header class="page-header">
            <h2>Panel de Control</h2>
            <p>Selecciona un módulo para desplegar sus opciones de trabajo.</p>
        </header>

        <div class="dashboard-grid">
            <div class="card ventas" onclick="toggleSubmenu('sub-ventas', this, 'panel-ventas')">
