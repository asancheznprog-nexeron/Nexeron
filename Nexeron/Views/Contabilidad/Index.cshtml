@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Módulo de Contabilidad";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Nexeron</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 2rem;
            color: #333;
        }

        .card {
            background-color: #fff;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: 0 auto;
        }

        .btn {
            display: inline-block;
            padding: 1rem 2rem;
            background-color: #6f42c1;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            margin-top: 1rem;
        }

        .btn-back {
            display: inline-block;
            margin-top: 1rem;
            color: #666;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>📊 Módulo de Contabilidad</h2>
        <p>Bienvenido al panel financiero. Selecciona una opción:</p>

        <a href="@Url.Action("Cuentas", "Contabilidad")" class="btn">Gestión de Cuentas</a>

        <br />
        <a href="@Url.Action("Index", "Home")" class="btn-back">← Volver al Home Principal</a>
    </div>
</body>
</html>