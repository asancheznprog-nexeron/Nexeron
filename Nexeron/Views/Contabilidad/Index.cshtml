@model IEnumerable<Nexeron.Models.CuentaModel>
@{
    Layout = null;
    ViewBag.Title = "Plan de Cuentas";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Nexeron</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            color: #333;
        }

        /* Barra superior */
        .navbar {
            background-color: #ffffff;
            padding: 1rem 2rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: bold;
            color: #6f42c1; /* Color morado para contabilidad */
            margin: 0;
            text-decoration: none;
        }

        .btn-back {
            background-color: #6c757d;
            color: white;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            font-size: 0.9rem;
            font-weight: bold;
        }

        /* Contenedor en dos columnas */
        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1.5rem;
            display: flex;
            gap: 2rem;
        }

        /* Columna Izquierda: Formulario */
        .column-form {
            flex: 1;
            max-width: 350px;
        }

        /* Columna Derecha: Tabla */
        .column-table {
            flex: 2;
        }

        .card {
            background-color: #ffffff;
            border-radius: 8px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

            .card h3 {
                margin-top: 0;
                margin-bottom: 1.5rem;
                border-bottom: 2px solid #f1f3f5;
                padding-bottom: 0.5rem;
                color: #495057;
            }

        /* Estilos del Formulario */
        .form-group {
            margin-bottom: 1.2rem;
        }

            .form-group label {
                display: block;
                margin-bottom: 0.5rem;
                color: #555;
                font-weight: bold;
                font-size: 0.9rem;
            }

        .form-control {
            width: 100%;
            padding: 0.6rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 1rem;
        }

        .btn-submit {
            width: 100%;
            padding: 0.7rem;
            background-color: #6f42c1;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            font-weight: bold;
            margin-top: 0.5rem;
        }

            .btn-submit:hover {
                background-color: #5a32a3;
            }

        /* Estilos de la Tabla */
        .table-cuentas {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
        }

            .table-cuentas th, .table-cuentas td {
                padding: 1rem;
                text-align: left;
                border-bottom: 1px solid #dee2e6;
            }

            .table-cuentas th {
                background-color: #f8f9fa;
                color: #495057;
                font-weight: bold;
            }

            .table-cuentas tr:hover {
                background-color: #f8f9fa;
            }

        .text-danger {
            color: #dc3545;
            font-size: 0.85rem;
        }

        .alert-error {
            background-color: #f8d7da;
            color: #721c24;
            padding: 0.75rem;
            border-radius: 4px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="~/" class="navbar-brand">Nexeron 📊 Contabilidad</a>
        <a href="@Url.Action("Index", "Home")" class="btn-back">← Volver al Panel</a>
    </nav>

    <div class="container">

        <div class="column-form">
            <div class="card">
                <h3>Nueva Cuenta</h3>

                @using (Html.BeginForm("CrearCuenta", "Contabilidad", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid && ViewData.ModelState[""] != null)
                    {
                        <div class="alert-error">
                            @Html.ValidationSummary(true)
                        </div>
                    }

                    <div class="form-group">
                        <label for="Codigo">Código Contable</label>
                        <input type="text" id="Codigo" name="Codigo" class="form-control" placeholder="ej: 5720001" required autocomplete="off" />
                    </div>

                    <div class="form-group">
                        <label for="Nombre">Nombre de la Cuenta</label>
                        <input type="text" id="Nombre" name="Nombre" class="form-control" placeholder="ej: Banco Santander" required autocomplete="off" />
                    </div>

                    <button type="submit" class="btn-submit">Guardar Cuenta</button>
                }
            </div>
        </div>

        <div class="column-table">
            <div class="card" style="padding: 0; overflow: hidden;">
                <table class="table-cuentas">
                    <thead>
                        <tr>
                            <th style="width: 30%;">Código</th>
                            <th style="width: 70%;">Nombre de la Cuenta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var cuenta in Model)
                            {
                                <tr>
                                    <td><strong>@cuenta.Codigo</strong></td>
                                    <td>@cuenta.Nombre</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" style="text-align: center; color: #888; padding: 2rem;">
                                    No hay cuentas creadas todavía. Utiliza el formulario de la izquierda.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

</body>
</html>