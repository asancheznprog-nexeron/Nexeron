@model IEnumerable<Nexeron.Models.ArticuloModel>
@{ 
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Gestión de Artículos"; 
    }

<h2>Gestión de Artículos</h2>

<p>
    <a href="@Url.Action("AddOrEdit", "Referencias", new { id = 0 })" class="btn btn-primary">Nuevo Artículo</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.articulo</td>
                <td>@item.desarti</td>
                <td>@item.descripcion</td>
                <td>
                    <a href="@Url.Action("AddOrEdit", "Referencias", new { id = item.codigo })" class="btn btn-warning">Modificar</a>
                    @using (Html.BeginForm("Borrar", "Referencias", new { id = item.codigo }, FormMethod.Post, new { style = "display:inline;" }))
                    {
                        <button type="submit" class="btn btn-danger" onclick="return confirm('¿Borrar registro?')">Borrar</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>