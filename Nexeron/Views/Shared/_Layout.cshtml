            </div>
        </nav>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script>
        function toggleMenu() {
            document.getElementById("miSidebar").classList.toggle("open");
            document.getElementById("mainWrapper").classList.toggle("shifted");
        }

        function toggleSidebarGroup(buttonElement) {
            var parentGroup = buttonElement.parentElement;
            var isAlreadyActive = parentGroup.classList.contains("active");
            var allGroups = document.querySelectorAll(".sidebar-group");

            for (var i = 0; i < allGroups.length; i++) {
                allGroups[i].classList.remove("active");
            }

            if (!isAlreadyActive) {
                parentGroup.classList.add("active");
            }
        }

        function toggleUserDropdown(event) {
            event.stopPropagation();
            document.getElementById("userDropdownMenu").classList.toggle("show");
        }

        window.onclick = function () {
            var menu = document.getElementById("userDropdownMenu");
            if (menu && menu.classList.contains("show")) {
                menu.classList.remove("show");
            }
        }
    </script>
</body>
</html>