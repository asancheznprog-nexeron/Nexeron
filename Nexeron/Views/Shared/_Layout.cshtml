@{
    
    string usuarioActual = Session["Usuario"] as string ?? "Usuario";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Nexeron</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            color: #333;
            overflow-x: hidden;
        }

        /* --- BARRA LATERAL (SIDEBAR) --- */
        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            z-index: 1000;
            top: 0;
            left: -250px; 
            background-color: #2c3e50;
            overflow-x: hidden;
            transition: 0.3s;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
        }

            .sidebar.open {
                left: 0; 
            }

        .sidebar-brand {
            color: #fff;
            font-size: 1.5rem;
            font-weight: bold;
            padding: 1.2rem;
            text-align: center;
            border-bottom: 1px solid #34495e;
            margin-bottom: 1rem;
        }

        .sidebar a {
            padding: 1rem 1.5rem;
            text-decoration: none;
            font-size: 1.05rem;
            color: #bdc3c7;
            display: block;
            transition: 0.2s;
        }

            .sidebar a:hover {
                color: #fff;
                background-color: #34495e;
                border-left: 4px solid #007bff;
            }

        /* Botón de cerrar sesión anclado al fondo */
        .sidebar .btn-logout {
            margin-top: auto; 
            background-color: #c0392b; 
            color: white;
            border-left: none;
            text-align: center;
        }

            .sidebar .btn-logout:hover {
                background-color: #e74c3c; 
                border-left: none;
            }

        /* --- CONTENIDO PRINCIPAL --- */
        .main-wrapper {
            transition: margin-left .3s;
        }

            .main-wrapper.shifted {
                margin-left: 250px;
            }

        /* --- BARRA SUPERIOR (NAVBAR) --- */
        .navbar {
            background-color: #2c3e50;
            padding: 1rem 1.5rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-right {
            display: flex;
            align-items: center;
        }

        .btn-toggle {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #ffffff;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            transition: background 0.2s;
        }

            .btn-toggle:hover {
                background-color: #34495e;
            }

        /* --- ZONA DE CONTENIDO DE CADA PANTALLA --- */
        .content-body {
            padding: 2rem;
        }
    </style>
</head>
<body>

    <div id="miSidebar" class="sidebar">
        <div class="sidebar-brand">Nexeron ERP</div>

        <a href="@Url.Action("Index", "Home")">🏠 Panel Principal</a>
        <a href="@Url.Action("Index", "Ofertas")">🛒 Ventas</a>
        <a href="@Url.Action("Index", "Compras")">🛍️ Compras</a>
        <a href="@Url.Action("Index", "Referencias")">📦 Referencias</a>
        <a href="@Url.Action("Index", "Cuentas")">📊 Contabilidad</a>

        <a href="@Url.Action("Logout", "Home")" class="btn-logout" style="display: flex; align-items: center; justify-content: center; gap: 8px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path>
                <line x1="12" y1="2" x2="12" y2="12"></line>
            </svg>
            Cerrar sesión
        </a>
    </div>

    <div id="mainWrapper" class="main-wrapper">

        <nav class="navbar">
            <div class="nav-left">
                <button class="btn-toggle" onclick="toggleMenu()" title="Abrir/Cerrar Menú">&#9776;</button>
                <h2 style="margin: 0; font-size: 1.3rem; color: #ffffff;">@ViewBag.Title</h2>
            </div>

            <div class="nav-right">
                <span style="color: #ffffff;">Hola, <strong>@usuarioActual</strong></span>
            </div>
        </nav>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script>
        function toggleMenu() {
            document.getElementById("miSidebar").classList.toggle("open");
            document.getElementById("mainWrapper").classList.toggle("shifted");
        }
    </script>
</body>
</html>