<script>
    var cacheUltimoFiltroCliente = "";

    $(document).ready(function() {
        var toastExito = sessionStorage.getItem("ToastExito");
        if (toastExito) {
            crearToast(toastExito, "success");
            sessionStorage.removeItem("ToastExito");
        }

        $('#tablaPedidos').DataTable({
            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
            "pageLength": 10,
            "order": [[0, "asc"]],
            "scrollY": "400px",
            "columnDefs": [ { "targets": 7, "orderable": false } ]
        });

        @if (TempData["MensajeExito"] != null) {
            <text>crearToast("@Html.Raw(TempData["MensajeExito"])", "success");</text>
        }
        @if (TempData["Error"] != null) {
            <text>crearToast("@Html.Raw(TempData["Error"])", "error");</text>
        }

        $(document).on('input', '.num-canti, .num-euros, .num-dtoarti, .num-ivarti', function() {
            var $modal = $(this).closest('.modal-overlay');
            calcularImporteFila($(this).closest('tr'));
            actualizarTotalesGlobales($modal);
        });

        $(document).on('click', function(e) {
            if (!$(e.target).closest('.txtCuentaProveedor, .boxSugerenciasProveedores').length) { $('.boxSugerenciasProveedores').hide(); }
            if (!$(e.target).closest('.txt-arti, .boxSugerenciasArticulos').length) { $('.boxSugerenciasArticulos').hide(); }
            if (!$(e.target).closest('#buscarProveedorAlb, #sugerenciasProveedorAlb').length) { $('#sugerenciasProveedorAlb').hide(); }
        });
    });

    function sincronizarReglaPago(selectElement) {
        var $opcion = $(selectElement).find('option:selected');
        var $modal = $(selectElement).closest('.modal-overlay');
        if ($opcion.val() !== "") {
            $modal.find('.txtNcb').val($opcion.data('cobros'));
            $modal.find('.txtVto').val($opcion.data('vto'));
            $modal.find('.txtDvto').val($opcion.data('dvto'));
        } else {
            $modal.find('.txtNcb').val(1); $modal.find('.txtVto').val(0); $modal.find('.txtDvto').val(0);
        }
    }

    function actualizarTotalesGlobales($modal) {
        var acumuladoBase = 0;
        var acumuladoIva = 0;

        $modal.find('.tblArticulos tbody tr').each(function() {
            var $f = $(this);
            if ($f.find('.txt-arti').val() === "") return true;

            var canti = parseFloat($f.find('.num-canti').val()) || 0;
            var euros = parseFloat($f.find('.num-euros').val()) || 0;
            var dto = parseFloat($f.find('.num-dtoarti').val()) || 0;
            var ivarti = parseFloat($f.find('.num-ivarti').val()) || 0;

            var baseLinea = canti * euros * (1 - (dto / 100));
            baseLinea = Math.round(baseLinea * 100) / 100;

            var ivaLinea = baseLinea * (ivarti / 100);
            ivaLinea = Math.round(ivaLinea * 100) / 100;

            acumuladoBase += baseLinea;
            acumuladoIva += ivaLinea;
        });

        var acumuladoTotal = acumuladoBase + acumuladoIva;

        $modal.find('.txt-total-base').val(acumuladoBase.toFixed(2));
        $modal.find('.txt-total-iva').val(acumuladoIva.toFixed(2));
        $modal.find('.txt-total-general').val(acumuladoTotal.toFixed(2));
    }

    function cargarYEditarPedido(numPedido) {
        $.ajax({
            url: '@Url.Action("ObtenerDetallePedido", "ComprasPedidos")',
            type: 'POST',
            data: { numPedido: numPedido },
            success: function(lineas) {
                if (lineas && lineas.length > 0) {
                    var primerRegistro = lineas[0];

                    $('#editNumPedido').val(numPedido);
                    $('#editFechPed').val(primerRegistro.FECHA);
                    $('#editFechEnt').val(primerRegistro.FECHENT || '');
                    $('#editCuenta').val(primerRegistro.CUENTA);
                    $('#editFcobro').val(primerRegistro.FCOBRO);
                    $('#editObservaciones').val(primerRegistro.OBSERVACIONES);

                    $('#editNombreFiscal').val(primerRegistro.NOMBRE_FISCAL);
                    $('#editCif').val(primerRegistro.CIF);
                    $('#editDireccion').val(primerRegistro.DIRECCION);
                    $('#editCp').val(primerRegistro.CP);
                    $('#editPoblacion').val(primerRegistro.POBLACION);
                    $('#editProvincia').val(primerRegistro.PROVINCIA);
                    $('#editTelefono').val(primerRegistro.TELEFONO);
                    $('#editEmail').val(primerRegistro.EMAIL);

                    sincronizarReglaPago(document.getElementById('editFcobro'));

                    var $tbody = $('#tablaArticulosEditar tbody');
                    if ($tbody.length == 0) {
                        $tbody = $('<tbody></tbody>');
                        $('#tablaArticulosEditar').append($tbody);
                    }
                    $tbody.empty();

                    for (var i = 0; i < lineas.length; i++) {
                        var item = lineas[i];
                        var importeFila = (parseFloat(item.CANTI) * parseFloat(item.EUROS) * (1 - (parseFloat(item.DTOARTI) / 100))).toFixed(2);

                        var trHtml = `
                        <tr class="fila-articulo">
                            <td>
                                <div style="position: relative;">
                                    <input type="text" class="input-tabla txt-arti" maxlength="50" autocomplete="off" onkeyup="buscarArticuloAjax(this)" value="${item.ARTI}" />
                                    <div class="sugerencias-autocompletado boxSugerenciasArticulos"></div>
                                </div>
                            </td>
                            <td><input type="text" class="input-tabla txt-desarti form-control-bloqueado" readonly value="${item.DESARTI}" /></td>
                            <td><input type="number" class="input-tabla num-canti" value="${parseFloat(item.CANTI).toFixed(2)}" min="0.01" step="0.01" /></td>
                            <td><select class="input-tabla txt-unidad">${generarOpcionesUnidad(item.UNIDAD)}</select></td>
                            <td><input type="number" class="input-tabla num-euros" value="${parseFloat(item.EUROS).toFixed(4)}" step="0.0001" /></td>
                            <td><input type="number" class="input-tabla num-dtoarti" value="${parseFloat(item.DTOARTI).toFixed(2)}" step="0.01" /></td>
                            <td><input type="text" class="input-tabla num-importe" value="${importeFila}" disabled style="background:#f1f3f5;font-weight:bold;text-align:right;" /></td>
                            <td><input type="number" class="input-tabla num-ivarti" value="${parseFloat(item.IVARTI).toFixed(2)}" step="0.01" /></td>
                            <td style="text-align: center;">
                                <button type="button" class="btn-tabla" onclick="agregarFilaArticulo(this)" style="color:#28a745;">+</button>
                                <button type="button" class="btn-tabla" onclick="eliminarFilaArticulo(this)" style="color:#dc3545;">&times;</button>
                            </td>
                        </tr>`;
                        $tbody.append(trHtml);
                    }
                    actualizarTotalesGlobales($('#modalEditar'));
                    $('#modalEditar').css('display', 'flex');
                }
            }
        });
    }

    function buscarProveedorAjax(input) {
        var term = input.value.trim();
        var $modal = $(input).closest('.modal-overlay');
        var $contenedor = $modal.find('.boxSugerenciasProveedores');

        if (term.length < 1) { $contenedor.hide().empty(); return; }
        if (term === cacheUltimoFiltroCliente) return;

        $.ajax({
            url: '@Url.Action("BuscarProveedores", "ComprasPedidos")',
            type: 'POST',
            data: { term: term },
            success: function(data) {
                $contenedor.empty();
                if (data && data.length > 0) {
                    data.forEach(function(c) {
                        var itemHtml = `<div class="sugerencia-item" onclick="injectarProveedor('${$modal.attr('id')}', '${c.CUENTA}', '${c.NOMBRE_FISCAL.replace(/'/g, "\\'")}', '${c.CIF}', '${c.DIRECCION.replace(/'/g, "\\'")}', '${c.CP}', '${c.POBLACION.replace(/'/g, "\\'")}', '${c.PROVINCIA.replace(/'/g, "\\'")}', '${c.TELEFONO}', '${c.EMAIL}')"><strong>${c.CUENTA}</strong> - ${c.NOMBRE_FISCAL}</div>`;
                        $contenedor.append(itemHtml);
                    });
                    $contenedor.show();
                } else { $contenedor.hide(); }
            }
        });
    }

    function injectarProveedor(modalId, cuenta, fiscal, cif, direccion, cp, poblacion, provincia, telefono, email) {
        var $m = $('#' + modalId);
        $m.find('.txtCuentaProveedor').val(cuenta);
        $m.find('.txtNombreFiscal').val(fiscal);
        $m.find('.txtCif').val(cif);
        $m.find('.txtDireccion').val(direccion);
        $m.find('.txtCp').val(cp);
        $m.find('.txtPoblacion').val(poblacion);
        $m.find('.txtProvincia').val(provincia);
        $m.find('.boxSugerenciasProveedores').hide();
    }

    function buscarArticuloAjax(input) {
        var term = input.value.trim();
        var $fila = $(input).closest('tr');
        var $contenedor = $(input).siblings('.boxSugerenciasArticulos');
        var $modal = $(input).closest('.modal-overlay');
        var provCodigo = $modal.find('.txtCuentaProveedor').val() || "";

        if (term.length < 1) {
            $contenedor.hide().empty();
            $fila.find('.txt-desarti, .txt-unidad, .num-importe').val('');
            $fila.find('.num-euros').val('0.0000');
            $fila.find('.num-ivarti').val('0.00');
            actualizarTotalesGlobales($modal);
            return;
        }

        $.ajax({
            url: '@Url.Action("BuscarArticulos", "ComprasPedidos")',
            type: 'POST',
            data: { term: term, proveedorCodigo: provCodigo },
            success: function(data) {
                $contenedor.empty();
                if (data && data.length > 0) {
                    data.forEach(function(a) {
                        var safeDesarti = a.DESARTI.replace(/"/g, '&quot;').replace(/'/g, "\\'");
                        var itemHtml = `<div class="sugerencia-item" onclick="seleccionarArticuloFila(this, '${a.ARTI}', '${safeDesarti}', '${a.UNIDAD}', '${a.IVARTI}', '${a.EUROS}', '${a.DTOARTI}')"><strong>${a.ARTI}</strong> - ${a.DESARTI}</div>`;
                        $contenedor.append(itemHtml);
                    });
                    $contenedor.show();
                } else { $contenedor.hide(); }
            }
        });
    }

    function seleccionarArticuloFila(elementoElement, arti, desarti, unidad, iva, tarifa, descuento) {
        var $fila = $(elementoElement).closest('tr');
        var $modal = $(elementoElement).closest('.modal-overlay');
        $fila.find('.txt-arti').val(arti);
        $fila.find('.txt-desarti').val(desarti);
        $fila.find('.txt-unidad').val(unidad);
        $fila.find('.num-ivarti').val(parseFloat(iva).toFixed(2));
        $fila.find('.num-euros').val(parseFloat(tarifa).toFixed(4));
        $fila.find('.num-dtoarti').val(parseFloat(descuento).toFixed(2));
        $fila.find('.boxSugerenciasArticulos').hide();
        calcularImporteFila($fila);
        actualizarTotalesGlobales($modal);
    }

    function calcularImporteFila($fila) {
        var canti = parseFloat($fila.find('.num-canti').val()) || 0;
        var euros = parseFloat($fila.find('.num-euros').val()) || 0;
        var dto = parseFloat($fila.find('.num-dtoarti').val()) || 0;
        var importe = canti * euros * (1 - (dto / 100));
        $fila.find('.num-importe').val(importe.toFixed(2));
    }

    function generarOpcionesUnidad(valorSeleccionado) {
        var html = "";
        var sel = (valorSeleccionado && valorSeleccionado.trim() !== "") ? valorSeleccionado.trim().toUpperCase() : "UD";
        @if (ViewBag.Unidades != null) {
            foreach (var u in (List<KeyValuePair<string, string>>)ViewBag.Unidades) {
                <text>
                var keyOpcion = '@u.Key'.trim().toUpperCase();
                html += '<option value="@u.Key" label="@u.Key"' + (sel === keyOpcion ? ' selected' : '') + '>@u.Key - @u.Value</option>';
                </text>
            }
        }
        return html || '<option value="UD" label="UD" selected>UD - UNIDADES</option>';
    }

    function agregarFilaArticulo(boton) {
        var nuevaFila = `
        <tr class="fila-articulo">
            <td>
                <div style="position: relative;">
                    <input type="text" class="input-tabla txt-arti" maxlength="50" autocomplete="off" onkeyup="buscarArticuloAjax(this)" />
                    <div class="sugerencias-autocompletado boxSugerenciasArticulos"></div>
                </div>
            </td>
            <td><input type="text" class="input-tabla txt-desarti form-control-bloqueado" readonly /></td>
            <td><input type="number" class="input-tabla num-canti" value="1.00" min="0.01" step="0.01" /></td>
            <td><select class="input-tabla txt-unidad">${generarOpcionesUnidad('UD')}</select></td>
            <td><input type="number" class="input-tabla num-euros" value="0.0000" step="0.0001" /></td>
            <td><input type="number" class="input-tabla num-dtoarti" value="0.00" step="0.01" /></td>
            <td><input type="text" class="input-tabla num-importe" value="0.00" disabled style="background:#f1f3f5;font-weight:bold;text-align:right;" /></td>
            <td><input type="number" class="input-tabla num-ivarti" value="0.00" step="0.01" /></td>
            <td style="text-align: center;">
                <button type="button" class="btn-tabla" onclick="agregarFilaArticulo(this)" style="color:#28a745;">+</button>
                <button type="button" class="btn-tabla" onclick="eliminarFilaArticulo(this)" style="color:#dc3545;">&times;</button>
            </td>
        </tr>`;
        $(boton).closest('tr').after(nuevaFila);
    }

    function eliminarFilaArticulo(btn) {
        var $table = $(btn).closest('table');
        var $modal = $(btn).closest('.modal-overlay');
        if ($table.find('tbody tr').length > 1) {
            $(btn).closest('tr').remove();
            actualizarTotalesGlobales($modal);
        } else { crearToast("Un pedido debe tener como mínimo una línea de artículo.", "error"); }
    }

    function empaquetarArticulosJson(modalId, targetHiddenId) {
        try {
            var listaArtiles = [];
            var algunaLineaLlena = false;

            $('#' + modalId + ' .tblArticulos tbody tr').each(function() {
                var $f = $(this);
                var inputArti = $f.find('.txt-arti').val();
                var inputDesarti = $f.find('.txt-desarti').val();

                var arti = inputArti ? inputArti.trim() : "";
                var desarti = inputDesarti ? inputDesarti.trim() : "";

                if (arti === "" && desarti === "") return;
                if (arti !== "" && desarti === "") { desarti = "Artículo " + arti; }

                var canti = parseFloat($f.find('.num-canti').val()) || 0;
                var inputUnidad = $f.find('.txt-unidad').val();
                var unidad = inputUnidad && inputUnidad.trim() !== "" ? inputUnidad.trim() : "UD";
                var euros = parseFloat($f.find('.num-euros').val()) || 0;
                var dto = parseFloat($f.find('.num-dtoarti').val()) || 0;
                var iva = parseFloat($f.find('.num-ivarti').val()) || 0;

                algunaLineaLlena = true;
                listaArtiles.push({ ARTI: arti, DESARTI: desarti, CANTI: canti, UNIDAD: unidad, EUROS: euros, DTOARTI: dto, IVARTI: iva });
            });

            if (!algunaLineaLlena) {
                crearToast("El pedido debe contener al menos un artículo válido.", "error");
                return false;
            }

            $('#' + targetHiddenId).val(JSON.stringify(listaArtiles));
            return true;
        } catch (err) {
            return false;
        }
    }

    function abrirModalCrear() { var $modal = $('#modalCrear'); actualizarTotalesGlobales($modal); $modal.css('display', 'flex'); }
    function abrirModalEliminar(numpedido, cliente) {
        $('#deletePedidoHidden').val(numpedido); $('#deletePedidoSpan').text(numpedido); $('#deleteClienteSpan').text(cliente); $('#modalEliminar').css('display', 'flex');
    }
    function cerrarModal(id) { $('#' + id).css('none'); $('#' + id).css('display', 'none'); }
    window.onclick = function(e) { if ($(e.target).hasClass('modal-overlay')) { $('.modal-overlay').css('display', 'none'); } }

    function crearToast(mensaje, tipo) {
        var container = document.getElementById('toastContainer');
        if (!container) return;
        var toast = document.createElement('div');
        toast.className = 'custom-toast ' + (tipo === 'success' ? 'toast-success' : 'toast-error');
        toast.innerText = mensaje;
        container.appendChild(toast);
        setTimeout(function() {
            toast.style.animation = 'fadeOutToast 0.3s ease-out forwards';
            setTimeout(function() { toast.remove(); }, 300);
        }, 4000);
    }

    function abrirModalAlbaranar() {
        $('#modalAlbaranar').css('display', 'flex');
        $('#buscarProveedorAlb').val('');
        $('#proveedorAlbCodigo').val('');
        $('#proveedorAlbNombre').val('');
        $('#datosProveedorAlbaran').hide();
        $('#lineasPedidoAlbaran').hide();
        $('#tablaPedidosAlbaran tbody').empty();
        $('#tablaLineasAlbaran tbody').empty();
        if ($.fn.DataTable.isDataTable('#tablaPedidosAlbaran')) {
            $('#tablaPedidosAlbaran').DataTable().destroy();
        }
    }

    function buscarProveedorAlbaran(input) {
        var term = $(input).val().trim();
        var $box = $('#sugerenciasProveedorAlb');
        if (term.length < 1) { $box.hide().empty(); return; }

        $.ajax({
            url: '@Url.Action("BuscarProveedores", "ComprasPedidos")',
            type: 'POST',
            data: { term: term },
            success: function(data) {
                $box.empty();
                if (data && data.length > 0) {
                    data.forEach(function(c) {
                        $box.append('<div class="sugerencia-item" onclick="seleccionarProveedorAlbaran(\'' + c.CUENTA + '\', \'' + c.NOMBRE_FISCAL.replace(/'/g, "\\'") + '\', \'' + c.CIF + '\', \'' + c.DIRECCION.replace(/'/g, "\\'") + '\', \'' + c.CP + '\', \'' + c.POBLACION.replace(/'/g, "\\'") + '\', \'' + c.PROVINCIA.replace(/'/g, "\\'") + '\')">' + c.CUENTA + ' - ' + c.NOMBRE_FISCAL + '</div>');
                    });
                    $box.show();
                } else { $box.hide(); }
            }
        });
    }

    function seleccionarProveedorAlbaran(cuenta, nombre, cif, direccion, cp, poblacion, provincia) {
        $('#buscarProveedorAlb').val(cuenta);
        $('#proveedorAlbCodigo').val(cuenta);
        $('#proveedorAlbNombre').val(nombre);
        $('#proveedorAlbCif').val(cif);
        $('#proveedorAlbDireccion').val(direccion);
        $('#proveedorAlbCp').val(cp);
        $('#proveedorAlbPoblacion').val(poblacion);
        $('#proveedorAlbProvincia').val(provincia);
        $('#sugerenciasProveedorAlb').hide();
        $('#datosProveedorAlbaran').show();
        $('#lineasPedidoAlbaran').hide();
        cargarPedidosPendientesProveedor(cuenta);
    }

    function cargarPedidosPendientesProveedor(cuenta) {
        $.ajax({
            url: '@Url.Action("ObtenerPedidosPendientesPorCliente", "ComprasAlbaranes")',
            type: 'POST',
            data: { cuenta: cuenta },
            success: function(data) {
                var $tbody = $('#tablaPedidosAlbaran tbody');
                $tbody.empty();
                if (data && data.length > 0) {
                    data.forEach(function(ped) {
                        var numPedidoVal = ped.NUMPEDIDO || ped.numpedido || '';
                        var fechaPedVal = ped.FECHAPED || ped.fechaped || ped.FECHPED || '';
                        var estadoVal = ped.ESTADO || ped.estado || '';

                        var row = '<tr onclick="seleccionarPedidoAlbaran(\'' + numPedidoVal + '\')" style="cursor:pointer;">' +
                                  '<td><strong>' + numPedidoVal + '</strong></td>' +
                                  '<td>' + fechaPedVal + '</td>' +
                                  '<td>' + (estadoVal == '101' ? 'Pendiente' : (estadoVal == '104' ? 'Parcial' : 'Activo')) + '</td></tr>';
                        $tbody.append(row);
                    });
                    if ($.fn.DataTable.isDataTable('#tablaPedidosAlbaran')) {
                        $('#tablaPedidosAlbaran').DataTable().destroy();
                    }
                    $('#tablaPedidosAlbaran').DataTable({
                        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
                        "pageLength": 5,
                        "order": [[0, "asc"]]
                    });
                } else {
                    $tbody.append('<tr><td colspan="3" style="text-align:center;">No hay pedidos pendientes para este proveedor.</td></tr>');
                }
            }
        });
    }

    function seleccionarPedidoAlbaran(numPedido) {
        $('#tablaPedidosAlbaran tbody tr').removeClass('fila-seleccionada');
        $('#tablaPedidosAlbaran tbody tr').filter(function() {
            return $(this).find('td:first').text().trim() === numPedido;
        }).addClass('fila-seleccionada');

        $('#pedidoSeleccionadoTitulo').text(numPedido);
        $.ajax({
            url: '@Url.Action("ObtenerLineasPedidoParaAlbaran", "ComprasAlbaranes")',
            type: 'POST',
            data: { numPedido: numPedido },
            success: function(lineas) {
                var $tbodyLineas = $('#tablaLineasAlbaran tbody');
                $tbodyLineas.empty();
                if (lineas && lineas.length > 0) {
                    lineas.forEach(function(l) {
                        var fila = '<tr data-numlinea="' + l.NUMLINEA + '" data-pendiente="' + l.Pendiente + '">' +
                                   '<td>' + l.ARTI + '</td>' +
                                   '<td>' + l.DESARTI + '</td>' +
                                   '<td>' + l.CantidadOriginal + '</td>' +
                                   '<td>' + l.CantidadAlbaranada + '</td>' +
                                   '<td>' + l.Pendiente + '</td>' +
                                   '<td><input type="number" class="input-tabla cant-albaranar" value="0.00" min="0.00" max="' + l.Pendiente + '" step="0.01" /></td>' +
                                   '</tr>';
                        $tbodyLineas.append(fila);
                    });
                    $('#lineasPedidoAlbaran').show();
                } else {
                    $tbodyLineas.append('<tr><td colspan="6" style="text-align:center;">No hay líneas pendientes.</td></tr>');
                    $('#lineasPedidoAlbaran').show();
                }
            }
        });
    }

    function procesarAlbaranDesdePedido() {
        var numPedido = $('#pedidoSeleccionadoTitulo').text().trim();
        if (!numPedido) {
            crearToast("Seleccione un pedido primero.", "error");
            return;
        }

        var lineas = [];
        $('#tablaLineasAlbaran tbody tr').each(function() {
            var numLinea = parseInt($(this).data('numlinea'));
            var pendiente = parseFloat($(this).data('pendiente'));
            var cantidad = parseFloat($(this).find('.cant-albaranar').val()) || 0;
            if (cantidad > 0) {
                if (cantidad > pendiente) {
                    crearToast("La cantidad supera la pendiente en la línea " + numLinea, "error");
                    lineas = null;
                    return false;
                }
                lineas.push({ NUMLINEA: numLinea, CANTI: cantidad });
            }
        });

        if (!lineas || lineas.length === 0) {
            if (lineas) crearToast("Introduzca al menos una cantidad.", "error");
            return;
        }

        $.ajax({
            url: '@Url.Action("CrearDesdePedido", "ComprasAlbaranes")',
            type: 'POST',
            data: { numPedido: numPedido, lineasJson: JSON.stringify(lineas) },
            success: function (res) {
                console.log("Exito");
                if (res.success) {
                    crearToast(res.mensaje, "success");
                    location.reload();
                } else {
                    crearToast(res.message, "error");
                }
            },
            error: function() {
                crearToast("Error de comunicación.", "error");
            }
        });
    }

    function exportarPedidoPdf(numPedido) {
        if (!numPedido) return;
        $.ajax({
            url: '@Url.Action("ObtenerDetallePedido", "ComprasPedidos")',
            type: 'POST',
            data: { numPedido: numPedido },
            success: function(lineas) {
                if (!lineas || lineas.length === 0) {
                    crearToast("No se encontraron datos para procesar el PDF.", "error");
                    return;
                }
                var primerRegistro = lineas[0];
                $('#pdf-num-pedido').text(numPedido.trim());
                $('#pdf-fecha').text(primerRegistro.FECHA);
                $('#pdf-fecha-entrega').text(primerRegistro.FECHENT || '-');
                $('#pdf-proveedor-nombre').text(primerRegistro.NOMBRE_FISCAL);
                $('#pdf-proveedor-cif').text(primerRegistro.CIF);
                $('#pdf-proveedor-cuenta').text(primerRegistro.CUENTA);
                $('#pdf-proveedor-direccion').text(primerRegistro.DIRECCION + ' ' + (primerRegistro.CP || '') + ' ' + (primerRegistro.POBLACION || '') + ' ' + (primerRegistro.PROVINCIA || ''));
                $('#pdf-forma-pago').text(primerRegistro.FCOBRO);

                if (primerRegistro.OBSERVACIONES && primerRegistro.OBSERVACIONES.trim() !== "") {
                    $('#pdf-observaciones').text(primerRegistro.OBSERVACIONES);
                    $('#pdf-observaciones-wrap').show();
                } else {
                    $('#pdf-observaciones-wrap').hide();
                }

                var $tbody = $('#pdf-tabla-lineas tbody').empty();
                var acumuladoBase = 0;
                var totalIvaAcumulado = 0;

                lineas.forEach(function(item) {
                    var cant = parseFloat(item.CANTI) || 0;
                    var euros = parseFloat(item.EUROS) || 0;
                    var dto = parseFloat(item.DTOARTI) || 0;
                    var ivarti = parseFloat(item.IVARTI) || 0;
                    var baseLinea = Math.round((cant * euros * (1 - (dto / 100))) * 100) / 100;
                    var ivaLinea = Math.round((baseLinea * (ivarti / 100)) * 100) / 100;

                    acumuladoBase += baseLinea;
                    totalIvaAcumulado += ivaLinea;

                    var filaHtml = `
                        <tr>
                            <td>${item.ARTI}</td>
                            <td style="white-space: normal;">${item.DESARTI}</td>
                            <td class="text-right">${cant.toFixed(2)}</td>
                            <td style="text-align:center;">${item.UNIDAD || 'UD'}</td>
                            <td class="text-right">${euros.toFixed(4)} €</td>
                            <td class="text-right" style="font-weight:600;">${baseLinea.toFixed(2)} €</td>
                        </tr>`;
                    $tbody.append(filaHtml);
                });

                $('#pdf-total-base').text(acumuladoBase.toFixed(2) + " €");
                var totalDocumento = acumuladoBase + totalIvaAcumulado;
                $('#pdf-total-general').text(totalDocumento.toFixed(2) + " €");

                var element = document.getElementById('invoice-template');
                var opcionesConfig = {
                    margin:       12,
                    filename:     'PedidoCompra_' + numPedido.trim() + '.pdf',
                    image:        { type: 'jpeg', quality: 0.98 },
                    html2canvas:  { scale: 2, logging: false, useCORS: true },
                    jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };

                $('#invoice-container').show();
                html2pdf().set(opcionesConfig).from(element).save().then(function() {
                    $('#invoice-container').hide();
                }).catch(function(err) {
                    $('#invoice-container').hide();
                    crearToast("Error al procesar la maquetación del PDF", "error");
                });
            },
            error: function() {
                crearToast("No se pudo conectar con el servidor para extraer el detalle.", "error");
            }
        });
    }
</script>