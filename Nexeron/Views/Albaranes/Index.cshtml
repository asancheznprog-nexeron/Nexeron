<script>
    var cacheUltimoFiltroCliente = "";

    $(document).ready(function () {
        var toastExito = sessionStorage.getItem("ToastExito");
        if (toastExito) {
            crearToast(toastExito, "success");
            sessionStorage.removeItem("ToastExito");
        }

        $('#tablaAlbaranes').DataTable({
            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
            "pageLength": 10,
            "order": [[0, "asc"]],
            "scrollY": "400px",
            "columnDefs": [{ "targets": 7, "orderable": false }]
        });

        @if (TempData["MensajeExito"] != null) {
            <text>crearToast("@Html.Raw(TempData["MensajeExito"])", "success");</text>
        }
        @if (TempData["Error"] != null) {
            <text>crearToast("@Html.Raw(TempData["Error"])", "error");</text>
        }

        $(document).on('input', '.num-canti, .num-euros, .num-dtoarti, .num-ivarti', function () {
            calcularImporteFila($(this).closest('tr'));
            actualizarTotalesGlobales($(this).closest('.modal-overlay'));
        });

        $(document).on('click', function(e) {
            if (!$(e.target).closest('.txtCuentaCliente, .boxSugerenciasClientes').length) $('.boxSugerenciasClientes').hide();
            if (!$(e.target).closest('.txt-arti, .boxSugerenciasArticulos').length) $('.boxSugerenciasArticulos').hide();
            if (!$(e.target).closest('#buscarPedidoInput, #sugerenciasPedidos').length) $('#sugerenciasPedidos').hide();
        });

        $('#formCrearAlbaran').submit(function (e) {
            e.preventDefault();
            if (!empaquetarArticulosJson('modalCrear', 'lineasJson')) return false;
            var numAlb = $('input[name="NUMALB"]').val().trim();
            if (numAlb === "") { crearToast("Número de albarán requerido.", "error"); return false; }
            $.ajax({
                url: '@Url.Action("ExisteNumeroAlbaran", "Albaranes")',
                type: 'POST',
                data: { numAlb: numAlb },
                success: function(res) {
                    if (res.existe) {
                        crearToast("El número de albarán ya existe.", "error");
                    } else {
                        $('#formCrearAlbaran')[0].submit();
                    }
                }
            });
        });

        $('#formEditarAlbaran').submit(function (e) {
            if (!empaquetarArticulosJson('modalEditar', 'lineasJsonModificadas')) e.preventDefault();
        });
    });

    function crearToast(mensaje, tipo) {
        var contenedor = document.getElementById('toastContainer');
        if (!contenedor) return;
        var toast = document.createElement('div');
        toast.className = 'custom-toast ' + (tipo === 'success' ? 'toast-success' : 'toast-error');
        toast.innerText = mensaje;
        contenedor.appendChild(toast);
        setTimeout(function () {
            toast.style.animation = 'fadeOutToast 0.3s ease-out forwards';
            setTimeout(function () {
                toast.remove();
            }, 300);
        }, 4000);
    }

    function buscarClienteAjax(input) {
        var term = input.value.trim();
        var $modal = $(input).closest('.modal-overlay');
        var $box = $modal.find('.boxSugerenciasClientes');
        if (term.length < 1) { $box.hide().empty(); return; }
        if (term === cacheUltimoFiltroCliente) return;
        $.ajax({
            url: '@Url.Action("BuscarClientes", "Albaranes")',
            type: 'POST',
            data: { term: term },
            success: function(data) {
                $box.empty();
                if (data && data.length > 0) {
                    data.forEach(function(c) {
                        $box.append('<div class="sugerencia-item" onclick="injectarCliente(\'' + $modal.attr('id') + '\',\'' + c.CUENTA + '\',\'' + c.NOMBRE_FISCAL.replace(/'/g, "\\'") + '\',\'' + c.CIF + '\',\'' + c.DIRECCION.replace(/'/g, "\\'") + '\',\'' + c.CP + '\',\'' + c.POBLACION.replace(/'/g, "\\'") + '\',\'' + c.PROVINCIA.replace(/'/g, "\\'") + '\')">' + c.CUENTA + ' - ' + c.NOMBRE_FISCAL + '</div>');
                    });
                    $box.show();
                } else { $box.hide(); }
            }
        });
    }

    function injectarCliente(modalId, cuenta, fiscal, cif, direccion, cp, poblacion, provincia) {
        var $m = $('#' + modalId);
        $m.find('.txtCuentaCliente').val(cuenta);
        $m.find('.txtNombreFiscal').val(fiscal);
        $m.find('.txtCif').val(cif);
        $m.find('.txtDireccion').val(direccion);
        $m.find('.txtCp').val(cp);
        $m.find('.txtPoblacion').val(poblacion);
        $m.find('.txtProvincia').val(provincia);
        $m.find('.boxSugerenciasClientes').hide();
    }

    function buscarArticuloAjax(input) {
        var term = input.value.trim();
        var $fila = $(input).closest('tr');
        var $box = $(input).siblings('.boxSugerenciasArticulos');
        if (term.length < 1) { $box.hide().empty(); return; }
        $.ajax({
            url: '@Url.Action("BuscarArticulos", "Albaranes")',
            type: 'POST',
            data: { term: term },
            success: function(data) {
                $box.empty();
                if (data && data.length > 0) {
                    data.forEach(function(a) {
                        $box.append('<div class="sugerencia-item" onclick="seleccionarArticuloFila(this,\'' + a.ARTI + '\',\'' + a.DESARTI.replace(/'/g, "\\'") + '\',\'' + a.UNIDAD + '\',\'' + a.IVARTI + '\')">' + a.ARTI + ' - ' + a.DESARTI + '</div>');
                    });
                    $box.show();
                } else { $box.hide(); }
            }
        });
    }

    function seleccionarArticuloFila(el, arti, desarti, unidad, iva) {
        var $fila = $(el).closest('tr');
        $fila.find('.txt-arti').val(arti);
        $fila.find('.txt-desarti').val(desarti);
        $fila.find('.txt-unidad').val(unidad);
        $fila.find('.num-ivarti').val(parseFloat(iva).toFixed(2));
        $fila.find('.boxSugerenciasArticulos').hide();
        calcularImporteFila($fila);
        actualizarTotalesGlobales($fila.closest('.modal-overlay'));
    }

    function calcularImporteFila($fila) {
        var canti = parseFloat($fila.find('.num-canti').val()) || 0;
        var euros = parseFloat($fila.find('.num-euros').val()) || 0;
        var dto = parseFloat($fila.find('.num-dtoarti').val()) || 0;
        var importe = canti * euros * (1 - (dto / 100));
        $fila.find('.num-importe').val(importe.toFixed(2));
    }

    function actualizarTotalesGlobales($modal) {
        var base = 0, iva = 0;
        $modal.find('.tblArticulos tbody tr').each(function() {
            var $f = $(this);
            if ($f.find('.txt-arti').val() === "") return;
            var c = parseFloat($f.find('.num-canti').val()) || 0;
            var e = parseFloat($f.find('.num-euros').val()) || 0;
            var d = parseFloat($f.find('.num-dtoarti').val()) || 0;
            var iv = parseFloat($f.find('.num-ivarti').val()) || 0;
            var bLinea = c * e * (1 - (d/100));
            var iLinea = bLinea * (iv/100);
            base += bLinea; iva += iLinea;
        });
        $modal.find('.txt-total-base').val(base.toFixed(2));
        $modal.find('.txt-total-iva').val(iva.toFixed(2));
        $modal.find('.txt-total-general').val((base+iva).toFixed(2));
    }

    function sincronizarReglaPago(select) {
        var $opt = $(select).find('option:selected');
        var $modal = $(select).closest('.modal-overlay');
        if ($opt.val() !== "") {
            $modal.find('.txtNcb').val($opt.data('cobros') || 1);
            $modal.find('.txtVto').val($opt.data('vto') || 0);
            $modal.find('.txtDvto').val($opt.data('dvto') || 0);
        } else {
            $modal.find('.txtNcb').val(1);
            $modal.find('.txtVto').val(0);
            $modal.find('.txtDvto').val(0);
        }
    }

    function generarOpcionesUnidad(valorSeleccionado) {
        var html = "";
        var sel = (valorSeleccionado && valorSeleccionado.trim() !== "") ? valorSeleccionado.trim().toUpperCase() : "UD";
        @if (ViewBag.Unidades != null) {
            foreach (var u in (List<KeyValuePair<string, string>>)ViewBag.Unidades) {
                <text>
                var keyOpcion = '@u.Key'.trim().toUpperCase();
                html += '<option value="@u.Key" label="@u.Key"' + (sel === keyOpcion ? ' selected' : '') + '>@u.Key - @u.Value</option>';
                </text>
            }
        }
        return html || '<option value="UD" label="UD" selected>UD - UNIDADES</option>';
    }

    function agregarFilaArticulo(btn) {
        var $modal = $(btn).closest('.modal-overlay');
        var nuevaFila = $(btn).closest('tr').clone();
        nuevaFila.find('input').val('');
        nuevaFila.find('.num-canti').val('1.00');
        nuevaFila.find('.num-euros').val('0.0000');
        nuevaFila.find('.num-dtoarti').val('0.00');
        nuevaFila.find('.num-ivarti').val('0.00');
        nuevaFila.find('.num-importe').val('0.00');
        nuevaFila.find('.txt-unidad').html(generarOpcionesUnidad('UD'));
        $(btn).closest('tr').after(nuevaFila);
    }

    function eliminarFilaArticulo(btn) {
        var $table = $(btn).closest('table');
        var $modal = $(btn).closest('.modal-overlay');
        if ($table.find('tbody tr').length > 1) {
            $(btn).closest('tr').remove();
            actualizarTotalesGlobales($modal);
        } else {
            crearToast("Debe haber al menos una línea.", "error");
        }
    }

    function empaquetarArticulosJson(modalId, targetHiddenId) {
        var lista = [];
        var llena = false;
        $('#' + modalId + ' .tblArticulos tbody tr').each(function() {
            var $f = $(this);
            var arti = ($f.find('.txt-arti').val() || "").trim();
            var desarti = ($f.find('.txt-desarti').val() || "").trim();
            if (arti === "" && desarti === "") return;
            if (arti !== "" && desarti === "") desarti = "Artículo " + arti;
            var canti = parseFloat($f.find('.num-canti').val()) || 0;
            var unidad = ($f.find('.txt-unidad').val() || "UD").trim();
            var euros = parseFloat($f.find('.num-euros').val()) || 0;
            var dto = parseFloat($f.find('.num-dtoarti').val()) || 0;
            var iva = parseFloat($f.find('.num-ivarti').val()) || 0;
            lista.push({ ARTI: arti, DESARTI: desarti, CANTI: canti, UNIDAD: unidad, EUROS: euros, DTOARTI: dto, IVARTI: iva });
            llena = true;
        });
        if (!llena) { crearToast("Al menos un artículo requerido.", "error"); return false; }
        $('#' + targetHiddenId).val(JSON.stringify(lista));
        return true;
    }

    function cargarYEditarAlbaran(numAlb) {
        $.ajax({
            url: '@Url.Action("ObtenerDetalleAlbaran", "Albaranes")',
            type: 'POST',
            data: { numAlbaran: numAlb },
            success: function(lineas) {
                if (lineas && lineas.length > 0) {
                    var primero = lineas[0];
                    $('#editNumAlb').val(numAlb);
                    $('#editNumAlbView').val(numAlb);
                    $('#editFechAlb').val(primero.FECHA);
                    $('#editCuenta').val(primero.CUENTA);
                    $('#editNombreFiscal').val(primero.NOMBRE_FISCAL);
                    $('#editCif').val(primero.CIF);
                    $('#editDireccion').val(primero.DIRECCION);
                    $('#editCp').val(primero.CP);
                    $('#editPoblacion').val(primero.POBLACION);
                    $('#editProvincia').val(primero.PROVINCIA);
                    $('#editFcobro').val(primero.FCOBRO);
                    $('#editObservaciones').val(primero.OBSERVACIONES);
                    $('#editNumPedido').val(primero.NUMPEDIDO);
                    sincronizarReglaPago(document.getElementById('editFcobro'));

                    var $tbody = $('#tablaArticulosEditar tbody').empty();
                    lineas.forEach(function(item) {
                        var importe = (item.CANTI * item.EUROS * (1 - item.DTOARTI/100)).toFixed(2);
                        var fila = `<tr>
                            <td><div style="position:relative;"><input type="text" class="input-tabla txt-arti" value="${item.ARTI}" onkeyup="buscarArticuloAjax(this)" /><div class="sugerencias-autocompletado boxSugerenciasArticulos"></div></div></td>
                            <td><input type="text" class="input-tabla txt-desarti form-control-bloqueado" readonly value="${item.DESARTI}" /></td>
                            <td><input type="number" class="input-tabla num-canti" value="${item.CANTI}" step="0.01" /></td>
                            <td><select class="input-tabla txt-unidad">${generarOpcionesUnidad(item.UNIDAD)}</select></td>
                            <td><input type="number" class="input-tabla num-euros" value="${item.EUROS.toFixed(4)}" step="0.0001" /></td>
                            <td><input type="number" class="input-tabla num-dtoarti" value="${item.DTOARTI.toFixed(2)}" step="0.01" /></td>
                            <td><input type="text" class="input-tabla num-importe" value="${importe}" disabled style="background:#f1f3f5;font-weight:bold;text-align:right;" /></td>
                            <td><input type="number" class="input-tabla num-ivarti" value="${item.IVARTI.toFixed(2)}" step="0.01" /></td>
                            <td style="text-align:center;"><button type="button" class="btn-tabla" onclick="agregarFilaArticulo(this)" style="color:#28a745;">+</button><button type="button" class="btn-tabla" onclick="eliminarFilaArticulo(this)" style="color:#dc3545;">×</button></td>
                        </tr>`;
                        $tbody.append(fila);
                    });
                    actualizarTotalesGlobales($('#modalEditar'));
                    if (primero.ESTADO == '102') {
                        $('#editFechAlb, #editFcobro, #editObservaciones').prop('disabled', true);
                        $('#tablaArticulosEditar input').prop('disabled', true);
                        $('#tablaArticulosEditar select').prop('disabled', true);
                        $('#btnGuardarEditar').hide();
                    } else {
                        $('#editFechAlb, #editFcobro, #editObservaciones').prop('disabled', false);
                        $('#tablaArticulosEditar input').prop('disabled', false);
                        $('#tablaArticulosEditar select').prop('disabled', false);
                        $('#btnGuardarEditar').show();
                    }
                    $('#modalEditar').css('display', 'flex');
                }
            }
        });
    }

    function abrirModalEliminar(numAlb, cliente) {
        $('#deleteAlbaranHidden').val(numAlb);
        $('#deleteAlbaranSpan').text(numAlb);
        $('#deleteClienteSpan').text(cliente);
        $('#modalEliminar').css('display', 'flex');
    }

    function abrirModalCrear() { $('#modalCrear').css('display', 'flex'); }
    function cerrarModal(id) { $('#' + id).css('display', 'none'); }
    window.onclick = function(e) { if (e.target.classList.contains('modal-overlay')) e.target.style.display = 'none'; }

    function abrirModalFacturar() {
        $('#modalFacturar').css('display', 'flex');
        $('#buscarClienteFac').val('');
        $('#clienteFacCodigo').val('');
        $('#clienteFacNombre').val('');
        $('#datosClienteFacturar').hide();
        $('#lineasAlbaranFacturar').hide();
        $('#tablaAlbaranesFacturar tbody').empty();
        $('#tablaLineasFacturar tbody').empty();
        if ($.fn.DataTable.isDataTable('#tablaAlbaranesFacturar')) {
            $('#tablaAlbaranesFacturar').DataTable().destroy();
        }
    }

    function buscarClienteFacturar(input) {
        var term = $(input).val().trim();
        var $box = $('#sugerenciasClienteFac');
        if (term.length < 1) { $box.hide().empty(); return; }

        $.ajax({
            url: '@Url.Action("BuscarClientes", "Albaranes")',
            type: 'POST',
            data: { term: term },
            success: function(data) {
                $box.empty();
                if (data && data.length > 0) {
                    data.forEach(function(c) {
                        $box.append('<div class="sugerencia-item" onclick="seleccionarClienteFacturar(\'' + c.CUENTA + '\', \'' + c.NOMBRE_FISCAL.replace(/'/g, "\\'") + '\', \'' + c.CIF + '\', \'' + c.DIRECCION.replace(/'/g, "\\'") + '\', \'' + c.CP + '\', \'' + c.POBLACION.replace(/'/g, "\\'") + '\', \'' + c.PROVINCIA.replace(/'/g, "\\'") + '\')">' + c.CUENTA + ' - ' + c.NOMBRE_FISCAL + '</div>');
                    });
                    $box.show();
                } else { $box.hide(); }
            }
        });
    }

    function seleccionarClienteFacturar(cuenta, nombre, cif, direccion, cp, poblacion, provincia) {
        $('#buscarClienteFac').val(cuenta);
        $('#clienteFacCodigo').val(cuenta);
        $('#clienteFacNombre').val(nombre);
        $('#clienteFacCif').val(cif);
        $('#clienteFacDireccion').val(direccion);
        $('#clienteFacCp').val(cp);
        $('#clienteFacPoblacion').val(poblacion);
        $('#clienteFacProvincia').val(provincia);
        $('#sugerenciasClienteFac').hide();
        $('#datosClienteFacturar').show();
        $('#lineasAlbaranFacturar').hide();
        cargarAlbaranesPendientesCliente(cuenta);
    }

    function cargarAlbaranesPendientesCliente(cuenta) {
        $.ajax({
            url: '@Url.Action("ObtenerAlbaranesPendientesPorCliente", "Albaranes")',
            type: 'POST',
            data: { cuenta: cuenta },
            success: function(data) {
                var $tbody = $('#tablaAlbaranesFacturar tbody');
                $tbody.empty();
                if (data && data.length > 0) {
                    data.forEach(function (alb) {
                        var row = '<tr onclick="seleccionarAlbaranFacturar(\'' + alb.NUMALB + '\')" style="cursor:pointer;">' +
                            '<td><strong>' + alb.NUMALB + '</strong></td>' +
                            '<td>' + alb.FECHALB + '</td>' +
                            '<td>' + (alb.ESTADO == '101' ? 'Pendiente' : (alb.ESTADO == '104' ? 'Parcial' : 'Completado')) + '</td></tr>';
                        $tbody.append(row);
                    });
                    if ($.fn.DataTable.isDataTable('#tablaAlbaranesFacturar')) {
                        $('#tablaAlbaranesFacturar').DataTable().destroy();
                    }
                    $('#tablaAlbaranesFacturar').DataTable({
                        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
                        "pageLength": 5,
                        "order": [[0, "asc"]]
                    });
                } else {
                    $tbody.append('<tr><td colspan="3" style="text-align:center;">No hay albaranes pendientes para este cliente.</td></tr>');
                }
            }
        });
    }

    function seleccionarAlbaranFacturar(numAlbaran) {
        $('#tablaAlbaranesFacturar tbody tr').removeClass('fila-seleccionada');
        $('#tablaAlbaranesFacturar tbody tr').filter(function() {
            return $(this).find('td:first').text().trim() === numAlbaran;
        }).addClass('fila-seleccionada');

        $('#albaranSeleccionadoTitulo').text(numAlbaran);
        $.ajax({
            url: '@Url.Action("ObtenerLineasAlbaranParaFacturar", "Albaranes")',
            type: 'POST',
            data: { numAlbaran: numAlbaran },
            success: function(lineas) {
                var $tbodyLineas = $('#tablaLineasFacturar tbody');
                $tbodyLineas.empty();
                if (lineas && lineas.length > 0) {
                    lineas.forEach(function(l) {
                        var fila = '<tr data-numlinea="' + l.NUMLINEA + '" data-pendiente="' + l.Pendiente + '">' +
                                    '<td>' + l.ARTI + '</td>' +
                                    '<td>' + l.DESARTI + '</td>' +
                                    '<td>' + l.CantidadOriginal + '</td>' +
                                    '<td>' + l.CantidadFacturada + '</td>' +
                                    '<td>' + l.Pendiente + '</td>' +
                                    '<td><input type="number" class="input-tabla cant-facturar" value="0.00" min="0.00" max="' + l.Pendiente + '" step="0.01" /></td>' +
                                    '</tr>';
                        $tbodyLineas.append(fila);
                    });
                    $('#lineasAlbaranFacturar').show();
                } else {
                    $tbodyLineas.append('<tr><td colspan="6" style="text-align:center;">No hay líneas pendientes de facturar.</td></tr>');
                    $('#lineasAlbaranFacturar').show();
                }
            }
        });
    }

    function procesarFacturaDesdeAlbaran() {
        var numAlbaran = $('#albaranSeleccionadoTitulo').text().trim();
        if (!numAlbaran) {
            crearToast("Seleccione un albarán primero.", "error");
            return;
        }

        var lineas = [];
        $('#tablaLineasFacturar tbody tr').each(function() {
            var numLinea = parseInt($(this).data('numlinea'));
            var pendiente = parseFloat($(this).data('pendiente'));
            var cantidad = parseFloat($(this).find('.cant-facturar').val()) || 0;
            if (cantidad > 0) {
                if (cantidad > pendiente) {
                    crearToast("La cantidad supera la pendiente en la línea " + numLinea, "error");
                    lineas = null;
                    return false;
                }
                lineas.push({ NUMLINEA: numLinea, CANTI: quantity = cantidad });
            }
        });

        if (!lineas || lineas.length === 0) {
            if (lineas) crearToast("Introduzca al menos una cantidad.", "error");
            return;
        }

        $.ajax({
            url: '@Url.Action("CrearDesdeAlbaran", "Facturas")',
            type: 'POST',
            data: { numAlbaran: numAlbaran, lineasJson: JSON.stringify(lineas) },
            success: function(res) {
                if (res.success) {
                    sessionStorage.setItem("ToastExito", res.mensaje);
                    location.reload();
                } else {
                    crearToast(res.message, "error");
                }
            },
            error: function() {
                crearToast("Error de comunicación.", "error");
            }
        });
    }

    function exportarAlbaranPdf(numAlbaran) {
        if (!numAlbaran) return;
        $.ajax({
            url: '@Url.Action("ObtenerDetalleAlbaran", "Albaranes")',
            type: 'POST',
            data: { numAlbaran: numAlbaran },
            success: function(lineas) {
                if (!lineas || lineas.length === 0) {
                    crearToast("No se encontraron datos para procesar el PDF.", "error");
                    return;
                }
                var primerRegistro = lineas[0];
                $('#pdf-num-albaran').text(numAlbaran.trim());
                $('#pdf-fecha').text(primerRegistro.FECHA);
                $('#pdf-pedido').text(primerRegistro.NUMPEDIDO || 'Manual');
                $('#pdf-cliente-nombre').text(primerRegistro.NOMBRE_FISCAL);
                $('#pdf-cliente-cif').text(primerRegistro.CIF);
                $('#pdf-cliente-cuenta').text(primerRegistro.CUENTA);
                $('#pdf-cliente-direccion').text(primerRegistro.DIRECCION + ' ' + primerRegistro.CP + ' ' + primerRegistro.POBLACION + ' ' + primerRegistro.PROVINCIA);
                $('#pdf-forma-pago').text(primerRegistro.FCOBRO);

                if (primerRegistro.OBSERVACIONES && primerRegistro.OBSERVACIONES.trim() !== "") {
                    $('#pdf-observaciones').text(primerRegistro.OBSERVACIONES);
                    $('#pdf-observaciones-wrap').show();
                } else {
                    $('#pdf-observaciones-wrap').hide();
                }

                var $tbody = $('#pdf-tabla-lineas tbody').empty();
                var acumuladoBase = 0;
                var totalIvaAcumulado = 0;

                lineas.forEach(function(item) {
                    var cant = parseFloat(item.CANTI) || 0;
                    var euros = parseFloat(item.EUROS) || 0;
                    var dto = parseFloat(item.DTOARTI) || 0;
                    var ivarti = parseFloat(item.IVARTI) || 0;
                    var baseLinea = Math.round((cant * euros * (1 - (dto / 100))) * 100) / 100;
                    var ivaLinea = Math.round((baseLinea * (ivarti / 100)) * 100) / 100;

                    acumuladoBase += baseLinea;
                    totalIvaAcumulado += ivaLinea;

                    var filaHtml = `
                        <tr>
                            <td>${item.ARTI}</td>
                            <td style="white-space: normal;">${item.DESARTI}</td>
                            <td class="text-right">${cant.toFixed(2)}</td>
                            <td style="text-align:center;">${item.UNIDAD}</td>
                            <td class="text-right">${euros.toFixed(4)} €</td>
                            <td class="text-right" style="font-weight:600;">${baseLinea.toFixed(2)} €</td>
                        </tr>`;
                    $tbody.append(filaHtml);
                });

                $('#pdf-total-base').text(acumuladoBase.toFixed(2) + " €");
                var totalDocumento = acumuladoBase + totalIvaAcumulado;
                $('#pdf-total-general').text(totalDocumento.toFixed(2) + " €");

                var element = document.getElementById('invoice-template');
                var opcionesConfig = {
                    margin:       12,
                    filename:     'Albaran_' + numAlbaran.trim() + '.pdf',
                    image:        { type: 'jpeg', quality: 0.98 },
                    html2canvas:  { scale: 2, logging: false, useCORS: true },
                    jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };

                $('#invoice-container').show();
                html2pdf().set(opcionesConfig).from(element).save().then(function() {
                    $('#invoice-container').hide();
                }).catch(function(err) {
                    $('#invoice-container').hide();
                    crearToast("Error al procesar la maquetación del PDF", "error");
                });
            },
            error: function() {
                crearToast("No se pudo conectar con el servidor para extraer el detalle.", "error");
            }
        });
    }
</script>